{
  "name": "workflow-manager",
  "packageManager": "bun@1.3.11",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "bun --filter '*' dev",
    "lint": "bunx biome check --write ./apps/",
    "clean": "rm -rf node_modules/ bun.lock"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js,jsx,json}": "bunx biome check --write"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}